CompileFlags:
  Remove:
    # ARM cross-compilation target — clangd on the host has no ARM sysroot,
    # so stripping these lets clangd use the host C++ headers (cstdint etc.)
    - -target
    - arm-none-eabi
    - -mthumb
    - -mcpu=*
    - -mfloat-abi=*
    - -mfpu=*
    - -fsingle-precision-constant
    - -falign-functions=*
    # C-only flags that are invalid for clang++ in C++ mode
    - -fgnu89-inline
    - -Wstrict-prototypes
    # Assembler/linker flags clangd does not understand
    - "-Wa,*"
    - "-Wl,*"
    - "-flto=*"
    # Dependency-file flags (not relevant for indexing)
    - -MD
    - -MP
    - -MF
    - .dep/build.d
